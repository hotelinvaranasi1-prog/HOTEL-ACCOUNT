rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Allow (for now, as authentication is removed)
    match /{document=**} {
      allow read, write: if true;
    }

    // Global Helpers (kept for compatibility, though currently always true)
    function isSignedIn() {
      return true;
    }

    function isStaff() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rooms
    match /rooms/{roomNumber} {
      function isValidRoom(data) {
        return data.number is string && data.number.size() <= 10 &&
               data.status in ['Available', 'Occupied', 'Cleaning', 'Maintenance'];
      }

      allow read: if true; 
      allow write: if isValidRoom(incoming());
    }

    // Bookings
    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return data.date is string &&
               data.room_number is string &&
               data.booking_type in ['Walk-in', 'OTA'] &&
               data.booking_status in ['Active', 'Cancelled', 'Completed'];
      }

      allow read: if true;
      allow create: if isValidBooking(incoming());
      allow update: if isValidBooking(incoming());
      allow delete: if true;
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Settings
    match /settings/{settingKey} {
      allow read: if true;
      allow write: if true;
    }
  }
}
